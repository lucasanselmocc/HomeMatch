# Django
DEBUG=True
SECRET_KEY=change-before-deploying

# Database (PostgreSQL)
DB_NAME=homematch_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db          # use "localhost" when running outside Docker
DB_PORT=5432

# Cloudflare R2 (image storage)
# Leave blank in local dev if you don't need photo upload.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
# Set to True to use local storage instead of Cloudflare R2
USE_LOCAL_STORAGE=

# AI Vision API
# Required only for the /api/ai-analysis/ endpoints.
# Point AI_API_BASE_URL at a local LM Studio instance for offline development.
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=

# E‑mail (envia mensagens para o console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@homematch.com

# URLs
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000