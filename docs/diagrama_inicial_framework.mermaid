    subgraph Infra["Banco / Models / Serviços externos"]
        UserModel["User Model"]
        PostModel["Post Model"]
        PhotoModel["Photo Model"]
        AttributeModel["Attribute Model"]
        MatchModel["MatchScore Model"]
        AIClient["Cliente de IA"]
        Parser["Parser de atributos"]
        DB["Banco de dados"]
    end

